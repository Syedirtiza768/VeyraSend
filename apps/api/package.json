{
  "name": "@veyrasend/api",
  "version": "0.0.0",
  "private": true,
  "type": "commonjs",
  "scripts": {
    "dev": "node --watch --env-file=../../.env -r ts-node/register src/main.ts",
    "build": "tsc -p tsconfig.build.json",
    "start": "node --env-file=../../.env dist/main.js",
    "typecheck": "tsc --noEmit",
    "lint": "echo 'lint:noop'",
    "test": "jest --config jest.config.js",
    "seed": "node --env-file=../../.env -r ts-node/register/transpile-only src/seed.ts",
    "seed:prod": "node dist/seed.js",
    "clean": "rimraf dist .tsbuildinfo"
  },
  "dependencies": {
    "@veyrasend/config": "workspace:*",
    "@veyrasend/shared": "workspace:*",
    "@veyrasend/db": "workspace:*",
    "@veyrasend/sendgrid": "workspace:*",
    "@veyrasend/twilio": "workspace:*",
    "@veyrasend/stripe": "workspace:*",
    "@nestjs/common": "^10.4.6",
    "@nestjs/core": "^10.4.6",
    "@nestjs/platform-express": "^10.4.6",
    "typeorm": "^0.3.20",
    "pg": "^8.13.1",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "ioredis": "^5.4.1",
    "bullmq": "^5.13.2",
    "express-session": "^1.18.1",
    "connect-redis": "^8.0.0",
    "cookie-parser": "^1.4.7",
    "argon2": "^0.41.1",
    "class-validator": "^0.14.1",
    "class-transformer": "^0.5.1",
    "uuid": "^10.0.0"
  },
  "devDependencies": {
    "typescript": "^5.6.3",
    "ts-node": "^10.9.2",
    "rimraf": "^6.0.1",
    "@types/node": "^22.9.0",
    "@types/uuid": "^10.0.0",
    "@types/pg": "^8.11.10",
    "@types/express": "^5.0.0",
    "@types/express-session": "^1.18.0",
    "@types/cookie-parser": "^1.4.7",
    "@nestjs/testing": "^10.4.6",
    "jest": "^29.7.0",
    "ts-jest": "^29.2.5",
    "@types/jest": "^29.5.14",
    "supertest": "^7.0.0",
    "@types/supertest": "^6.0.2"
  }
}
