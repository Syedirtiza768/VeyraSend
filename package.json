{
  "name": "veyrasend",
  "version": "0.0.0",
  "private": true,
  "packageManager": "pnpm@9.12.0",
  "engines": {
    "node": ">=20.10.0",
    "pnpm": ">=9.0.0"
  },
  "scripts": {
    "predev": "pnpm -r --filter @veyrasend/config --filter @veyrasend/shared --filter @veyrasend/db --filter @veyrasend/sendgrid build",
    "dev": "pnpm -r --parallel dev",
    "prebuild": "pnpm -r --filter @veyrasend/config --filter @veyrasend/shared --filter @veyrasend/db --filter @veyrasend/sendgrid build",
    "build": "pnpm -r build",
    "pretypecheck": "pnpm -r --filter @veyrasend/config --filter @veyrasend/shared --filter @veyrasend/db --filter @veyrasend/sendgrid build",
    "typecheck": "pnpm -r typecheck",
    "lint": "pnpm -r lint",
    "test": "pnpm -r test",
    "db:migration:generate": "pnpm --filter @veyrasend/db migration:generate",
    "db:migration:run": "pnpm --filter @veyrasend/db migration:run",
    "db:migration:revert": "pnpm --filter @veyrasend/db migration:revert",
    "docker:up": "docker compose up --build",
    "docker:down": "docker compose down",
    "clean": "pnpm -r --parallel clean && rimraf node_modules"
  },
  "devDependencies": {
    "turbo": "^2.3.3",
    "typescript": "^5.6.3",
    "rimraf": "^6.0.1",
    "prettier": "^3.3.3"
  }
}
