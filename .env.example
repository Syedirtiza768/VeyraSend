# ---- VeyraSend environment ----
# Copy to .env and fill in. The API fails fast at boot if any required var
# is missing or invalid. Never commit .env.

NODE_ENV=development

# API
API_PORT=4000
WEB_PORT=3040

# Database (Postgres 16)
DATABASE_URL=postgres://veyrasend:veyrasend@localhost:5435/veyrasend

# Queue / cache / sessions (Redis 7)
REDIS_URL=redis://localhost:6381

# Session cookie signing key (>= 32 bytes). Generate with:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
SESSION_SECRET=replace-with-a-long-random-hex-string

# ---- SendGrid (ADR-0001: parent account + subusers) ----
# Parent key provisions/manages subusers. Leave SENDGRID_MOCK_MODE=true until
# a real Subuser-capable plan is connected.
SENDGRID_MOCK_MODE=true
SENDGRID_PARENT_API_KEY=

# SendGrid Event Webhook verification key (SendGrid signed events).
SENDGRID_WEBHOOK_VERIFICATION_KEY=

# Inbound Parse (Phase 7) — domain whose MX points at SendGrid.
INBOUND_PARSE_DOMAIN=

# Shared secret query param for POST /api/webhooks/inbound (Phase 13 hardening).
SENDGRID_INBOUND_PARSE_SECRET=

# At-rest encryption for tenant SendGrid API keys (32 bytes, 64 hex chars).
# Required when SENDGRID_MOCK_MODE=false. Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=

# ---- Docker Compose ----
# For `docker compose up` (full stack), copy .env.docker.example to .env instead.
# Internal service URLs are set in docker-compose.yml (postgres/redis hostnames).
# Host dev with infra-only compose uses the localhost URLs above:
#   docker compose up -d postgres redis

# ---- Twilio (ADR-0007: parent account + subaccounts) ----
TWILIO_MOCK_MODE=true
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_MESSAGING_SERVICE_SID=
TWILIO_VOICE_APP_SID=
