{
  "name": "@veyrasend/sendgrid",
  "version": "0.0.0",
  "private": true,
  "type": "commonjs",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "require": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -b",
    "dev": "tsc -b --watch --preserveWatchOutput",
    "typecheck": "tsc --noEmit",
    "lint": "echo 'lint:noop'",
    "clean": "rimraf dist .tsbuildinfo"
  },
  "dependencies": {
    "@veyrasend/config": "workspace:*",
    "@sendgrid/client": "^8.1.5",
    "@sendgrid/mail": "^8.1.4",
    "@sendgrid/eventwebhook": "^8.0.0"
  },
  "devDependencies": {
    "typescript": "^5.6.3",
    "rimraf": "^6.0.1"
  }
}
